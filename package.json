{
  "name": "speakly-app",
  "private": true,
  "scripts": {
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "dev": "node scripts/run-stack.js",
    "start": "node scripts/run-stack.js",
    "start:prod": "node scripts/run-stack.js prod",
    "start:backend": "npm --prefix backend run start",
    "start:frontend": "npm --prefix frontend run dev",
    "test": "npm --prefix backend test && npm --prefix frontend test"
  }
}
